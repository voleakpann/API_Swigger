PORT=8081

# Postgres connection (single URL preferred). Falls back to localhost defaults if unset.
DATABASE_URL=postgresql://postgres:voleak@localhost:5432/crud_api

# Firebase Admin service account JSON (server-side ID-token verification).
# Generate from Firebase Console → Project Settings → Service accounts → Generate new private key.
# Leave blank to disable verification (the /api/auth/verify-otp endpoint will return 503 until set).
FIREBASE_CREDENTIALS_PATH=

# Phone that auto-promotes to ADMIN on verify-otp. Use the +855... E.164 form.
# Leave blank to disable bootstrap; new users will then have role=null and need an existing admin to promote them.
BOOTSTRAP_ADMIN_PHONE=+855964040006
